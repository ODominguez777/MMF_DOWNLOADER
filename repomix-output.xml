.model-id-row-id {
    font-family: "IBM Plex Mono", "Consolas", monospace;
    font-size: 0.84rem;
    font-weight: 700;
    color: #0b4f4a;
}

.model-id-row-name {
    display: block;
    font-size: 0.88rem;
    color: var(--ink);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.model-id-row-name-group {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
}

.model-id-row-creator {
    display: flex;
    align-items: center;
    gap: 6px;
    min-width: 0;
}

.model-id-row-creator-id {
    flex: 0 0 auto;
    border: 1px solid rgba(16, 35, 29, 0.18);
    border-radius: 999px;
    padding: 1px 7px;
    font-family: "IBM Plex Mono", "Consolas", monospace;
    font-size: 0.69rem;
    font-weight: 700;
    color: #0b4f4a;
    background: rgba(255, 255, 255, 0.9);
}

.model-id-row-creator-details {
    min-width: 0;
    font-size: 0.76rem;
    color: var(--muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.model-id-row-remove {
    border: 1px solid rgba(16, 35, 29, 0.14);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.9);
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 700;
    padding: 4px 8px;
    cursor: pointer;
}

.model-id-row-remove:disabled {
    opacity: 0.45;
    cursor: not-allowed;
}

.model-id-row-remove:not(:disabled):hover {
    color: var(--bad);
    border-color: rgba(191, 47, 47, 0.35);
}

.model-id-row-invalid .model-id-row-id {
    color: #8f2222;
}

.model-id-row-duplicate .model-id-row-id {
    color: #8f5a00;
}

.model-id-row-completed {
    background: rgba(30, 143, 73, 0.08);
}

.model-id-row-completed .model-id-row-id {
    color: #176438;
}

.auth-actions {
    margin-top: 4px;
}

.session-status {
    margin: 8px 0 0;
    padding: 8px 10px;
    border-radius: 10px;
    font-size: 0.86rem;
    font-weight: 600;
    border: 1px solid var(--edge);
}

.session-status-unknown {
    background: rgba(16, 35, 29, 0.04);
    color: var(--muted);
}

.session-status-ok {
    background: rgba(30, 143, 73, 0.12);
    color: #166534;
    border-color: rgba(30, 143, 73, 0.28);
}

.session-status-warn {
    background: rgba(181, 105, 0, 0.12);
    color: #8f5a00;
    border-color: rgba(181, 105, 0, 0.28);
}

.session-status-bad {
    background: rgba(191, 47, 47, 0.1);
    color: #8f2222;
    border-color: rgba(191, 47, 47, 0.28);
}

.subheading {
    font-size: 0.95rem;
    margin: 14px 0 8px;
}

.button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
    margin-top: 14px;
}

.btn {
    border: 1px solid transparent;
    border-radius: 10px;
    padding: 9px 13px;
    font-weight: 700;
    font-size: 0.88rem;
    cursor: pointer;
    transition: transform 140ms ease, box-shadow 180ms ease, background 180ms ease;
}

.btn:hover {
    transform: translateY(-1px);
}

.btn:active {
    transform: translateY(0);
}

.btn-primary {
    background: linear-gradient(145deg, var(--accent), var(--accent-strong));
    color: #ffffff;
    box-shadow: 0 8px 18px rgba(15, 118, 110, 0.26);
}

.btn-secondary {
    background: #ffffff;
    color: var(--ink);
    border-color: rgba(16, 35, 29, 0.2);
}

.btn-danger {
    background: linear-gradient(145deg, #d14343, #af2a2a);
    color: #ffffff;
    box-shadow: 0 8px 18px rgba(191, 47, 47, 0.24);
}

.btn:disabled {
    opacity: 0.55;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
}

.status {
    margin: 12px 0 0;
    font-size: 0.88rem;
    font-weight: 600;
}

.status-neutral {
    color: var(--muted);
}

.status-ok {
    color: var(--ok);
}

.status-warn {
    color: var(--warn);
}

.status-bad {
    color: var(--bad);
}

.requirements-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 8px;
}

.requirements-list li {
    display: flex;
    gap: 9px;
    align-items: flex-start;
    padding: 8px 10px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.76);
    border: 1px solid rgba(16, 35, 29, 0.08);
}

.dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    margin-top: 6px;
    flex: 0 0 auto;
}

.dot-pass {
    background: var(--ok);
}

.dot-fail {
    background: var(--bad);
}

.dot-warn {
    background: var(--warn);
}

.req-copy {
    font-size: 0.9rem;
}

.progress-track {
    margin-top: 12px;
    height: 12px;
    border-radius: 999px;
    background: rgba(16, 35, 29, 0.12);
    overflow: hidden;
}

.progress-bar {
    height: 100%;
    width: 0;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--accent), var(--accent-warm));
    transition: width 220ms ease;
}

.pipeline-progress-panel {
    margin: 12px 0 4px;
    padding: 12px 14px;
    border: 1px solid rgba(15, 118, 110, 0.18);
    border-left: 4px solid var(--accent);
    border-radius: 8px;
    background: rgba(248, 251, 250, 0.92);
}

.pipeline-progress-panel.hidden {
    display: none;
}

.pipeline-progress-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 8px;
}

.pipeline-progress-label {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--ink);
}

.pipeline-progress-percent {
    font-family: "IBM Plex Mono", "Consolas", monospace;
    font-size: 0.86rem;
    font-weight: 700;
    color: #0b4f4a;
}

.pipeline-progress-track {
    margin-top: 0;
    height: 14px;
    background: rgba(16, 35, 29, 0.1);
}

.pipeline-progress-track .progress-bar {
    position: relative;
    overflow: hidden;
    background-image:
        repeating-linear-gradient(45deg, rgba(255, 255, 255, 0.24) 0 8px, transparent 8px 16px),
        linear-gradient(90deg, var(--accent), var(--accent-warm));
}

.pipeline-progress-track .progress-bar::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.32), transparent);
    transform: translateX(-100%);
    animation: progress-sheen 1.8s ease-in-out infinite;
}

.pipeline-progress-detail {
    margin: 8px 0 0;
}

@keyframes progress-sheen {
    to {
        transform: translateX(100%);
    }
}

.preview {
    margin: 8px 0 0;
    border-radius: 12px;
    border: 1px solid rgba(16, 35, 29, 0.16);
    background: #f5f8f7;
    color: #173128;
    font-family: "IBM Plex Mono", "Consolas", monospace;
    padding: 11px;
    font-size: 0.84rem;
    min-height: 84px;
    max-height: 220px;
    max-width: 100%;
    overflow: auto;
}

.steps {
    margin: 0;
    padding-left: 20px;
    display: grid;
    gap: 10px;
}

.steps li {
    padding-right: 6px;
}

.steps code {
    display: block;
    margin-top: 5px;
    border-radius: 8px;
    background: #f4faf8;
    border: 1px solid rgba(16, 35, 29, 0.16);
    padding: 7px 9px;
    font-family: "IBM Plex Mono", "Consolas", monospace;
    font-size: 0.84rem;
    overflow-x: auto;
}

.form-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px 12px;
}

.path-picker,
.secret-field {
    display: flex;
    gap: 8px;
    align-items: center;
}

.path-picker input,
.secret-field input {
    flex: 1 1 auto;
    min-width: 0;
}

.secret-toggle {
    flex: 0 0 auto;
}

.btn-inline {
    white-space: nowrap;
    padding-left: 12px;
    padding-right: 12px;
}

.json-toolbar {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto auto;
    gap: 8px;
    align-items: center;
    margin-top: 8px;
}

.json-toolbar select {
    margin: 0;
}

.json-viewer {
    margin-top: 10px;
    min-height: 220px;
    max-height: 420px;
    max-width: 100%;
    white-space: pre;
}

.run-grid {
    margin-top: 12px;
    display: grid;
    gap: 8px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
}

#runExecuteBtn {
    grid-column: 1 / -1;
}

#runNextBatchBtn {
    grid-column: 1 / -1;
}

.terminal-log {
    margin-top: 10px;
    min-height: 200px;
    max-height: 360px;
    white-space: pre-wrap;
    background: #0f1f1a;
    color: #d9f4ea;
    border-color: rgba(14, 120, 102, 0.34);
}

.footer {
    color: var(--muted);
    font-size: 0.88rem;
    text-align: center;
    padding: 4px 0 8px;
}

.reveal {
    opacity: 0;
    transform: translateY(9px);
    animation: reveal-up 480ms ease forwards;
}

.delay-1 { animation-delay: 60ms; }
.delay-2 { animation-delay: 120ms; }
.delay-3 { animation-delay: 180ms; }
.delay-4 { animation-delay: 240ms; }
.delay-5 { animation-delay: 300ms; }
.delay-6 { animation-delay: 360ms; }

@keyframes reveal-up {
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@media (max-width: 980px) {
    body {
        padding: 16px;
    }

    .app-shell {
        width: min(1180px, calc(100vw - 32px));
    }

    .hero {
        flex-direction: column;
        align-items: flex-start;
    }

    .stat-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .split-layout {
        grid-template-columns: 1fr;
    }

    .form-grid {
        grid-template-columns: 1fr;
    }

    .path-picker {
        align-items: stretch;
    }

    .json-toolbar {
        grid-template-columns: 1fr;
    }

    .run-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }
}

@media (max-width: 560px) {
    .stat-grid {
        grid-template-columns: 1fr;
    }

    .brand-wrap {
        align-items: flex-start;
    }

    .brand-mark {
        width: 46px;
        height: 46px;
        border-radius: 12px;
        font-size: 0.82rem;
    }

    .panel {
        padding: 14px;
    }

    .run-grid {
        grid-template-columns: 1fr;
    }

    .path-picker {
        flex-direction: column;
    }

    .btn-inline {
        width: 100%;
    }
}
</file>

<file path="gui/index.html">
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; base-uri 'self'; form-action 'self'">
    <title>Bulk Downloader Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <div class="bg-grid" aria-hidden="true"></div>
    <div class="bg-orb bg-orb-a" aria-hidden="true"></div>
    <div class="bg-orb bg-orb-b" aria-hidden="true"></div>

    <div id="desktopGate" class="desktop-gate hidden" role="dialog" aria-modal="true" aria-labelledby="desktopGateTitle">
        <section class="desktop-card">
            <h2 id="desktopGateTitle">Desktop startup dependency check</h2>
            <p id="depSummary" class="hint">Checking dependencies...</p>
            <ul id="depList" class="requirements-list" aria-live="polite"></ul>
            <pre id="depLog" class="preview dep-log">No installer output yet.</pre>
            <div class="button-row">
                <button id="depRefreshBtn" type="button" class="btn btn-secondary">Refresh check</button>
                <button id="depInstallBtn" type="button" class="btn btn-primary">Install missing</button>
                <button id="depSkipBtn" type="button" class="btn btn-secondary">Continue without install</button>
            </div>
        </section>
    </div>

    <main class="app-shell">
        <header class="hero reveal delay-1">
            <div class="brand-wrap">
                <div class="brand-mark">BD</div>
                <div>
                    <h1>Bulk Downloader</h1>
                    <p>Bulk download of 3D models.</p>
                </div>
            </div>
            <span id="connectionBadge" class="badge badge-offline">Not ready</span>
        </header>

        <section class="stat-grid reveal delay-2" aria-label="Overview">
            <article class="stat-card">
                <h2 id="validIdCount">0</h2>
                <p>Valid model IDs</p>
            </article>
            <article class="stat-card">
                <h2 id="invalidLineCount">0</h2>
                <p>Invalid lines</p>
            </article>
            <article class="stat-card">
                <h2 id="requiredPassCount">0 / 5</h2>
                <p>Required checks</p>
            </article>
            <article class="stat-card">
                <h2 id="readinessPct">0%</h2>
                <p>Readiness</p>
            </article>
        </section>

        <section class="split-layout">
            <section class="panel reveal delay-3" aria-labelledby="configuration-heading">
                <div class="panel-header">
                    <h2 id="configuration-heading">Configuration</h2>
                </div>

                <div class="button-row auth-actions">
                    <button id="openMmfLoginBtn" type="button" class="btn btn-primary">Open MyMiniFactory</button>
                    <button id="captureMmfSessionBtn" type="button" class="btn btn-secondary">Capture session</button>
                    <button id="checkSessionBtn" type="button" class="btn btn-secondary">Check session</button>
                </div>
                <p id="sessionStatus" class="session-status session-status-unknown" aria-live="polite">Session: not checked</p>
                <p class="hint">Recommended: Open MMF → Capture session → Auto load my IDs.</p>

                <details class="advanced-panel">
                    <summary>Advanced: manual credentials (fallback)</summary>
                    <label for="phpSessidInput">Cookie PHPSESSID</label>
                    <div class="secret-field">
                        <input id="phpSessidInput" type="password" autocomplete="off" placeholder="Paste only the PHPSESSID value">
                        <button type="button" class="btn btn-secondary btn-inline secret-toggle" data-target="phpSessidInput" aria-label="Show PHPSESSID">Show</button>
                    </div>
                    <label for="cfClearanceInput">Cookie cf_clearance</label>
                    <div class="secret-field">
                        <input id="cfClearanceInput" type="password" autocomplete="off" placeholder="Paste only the cf_clearance value">
                        <button type="button" class="btn btn-secondary btn-inline secret-toggle" data-target="cfClearanceInput" aria-label="Show cf_clearance">Show</button>
                    </div>
                    <label for="jwtInput">Medusa JWT (medusa_auth_token)</label>
                    <div class="secret-field">
                        <input id="jwtInput" type="password" autocomplete="off" placeholder="Paste medusa_auth_token JWT from Local Storage">
                        <button type="button" class="btn btn-secondary btn-inline secret-toggle" data-target="jwtInput" aria-label="Show Medusa JWT">Show</button>
                    </div>
                    <label for="publishableKeyInput">x-publishable-api-key (pk...)</label>
                    <div class="secret-field">
                        <input id="publishableKeyInput" type="password" autocomplete="off" placeholder="Paste key that starts with pk_">
                        <button type="button" class="btn btn-secondary btn-inline secret-toggle" data-target="publishableKeyInput" aria-label="Show publishable API key">Show</button>
                    </div>
                    <p class="hint">Use only if Capture session fails. Open your MMF profile in the sign-in window so the publishable key can be detected.</p>
                </details>

                <label>Your models</label>

                <fieldset class="catalog-load-mode" aria-labelledby="catalogLoadModeLegend">
                    <legend id="catalogLoadModeLegend">Auto load source</legend>
                    <div class="catalog-load-grid">
                        <label class="catalog-load-card">
                            <input type="radio" name="catalogLoadMode" value="listing">
                            <span class="catalog-load-card-inner">
                                <span class="catalog-load-card-radio" aria-hidden="true"></span>
                                <span class="catalog-load-card-text">
                                    <span class="catalog-load-card-title">Listing</span>
                                    <span class="catalog-load-card-desc">Models you created — only entries where your account is the creator.</span>
                                </span>
                            </span>
                        </label>
                        <label class="catalog-load-card">
                            <input type="radio" name="catalogLoadMode" value="library" checked>
                            <span class="catalog-load-card-inner">
                                <span class="catalog-load-card-radio" aria-hidden="true"></span>
                                <span class="catalog-load-card-text">
                                    <span class="catalog-load-card-title">Library</span>
                                    <span class="catalog-load-card-desc">Your full data library — creations, purchases, gifts, tribes, and downloads.</span>
                                </span>
                            </span>
                        </label>
                        <label class="catalog-load-card">
                            <input type="radio" name="catalogLoadMode" value="creator">
                            <span class="catalog-load-card-inner">
                                <span class="catalog-load-card-radio" aria-hidden="true"></span>
                                <span class="catalog-load-card-text">
                                    <span class="catalog-load-card-title">Creator filter</span>
                                    <span class="catalog-load-card-desc">Library entries filtered by a creator ID that you choose manually.</span>
                                </span>
                            </span>
                        </label>
                    </div>
                </fieldset>

                <div id="creatorFilterGroup" class="creator-filter-group hidden">
                    <label for="creatorIdFilterInput">Creator ID filter</label>
                    <input id="creatorIdFilterInput" type="text" placeholder="e.g. 123456">
                    <p class="hint">Used only in Creator filter mode. It matches entries by creatorId.</p>
                </div>

                <div class="model-tools-grid">
                    <div>
                        <label for="modelSearchInput">Search loaded models and creators</label>
                        <div class="search-inline">
                            <input id="modelSearchInput" type="text" placeholder="Search by model name, creator username, creator name, creator ID, or model ID">
                            <button id="modelSearchClearBtn" type="button" class="btn btn-secondary btn-inline">Clear</button>
                        </div>
                        <p class="hint">Includes creator username and creator name fallback for entries where username is missing.</p>
                    </div>
                    <div>
                        <label for="batchSizeSelect">Batch size</label>
                        <select id="batchSizeSelect">
                            <option value="10">10 models</option>
                            <option value="25">25 models</option>
                            <option value="50">50 models</option>
                            <option value="100">100 models</option>
                            <option value="all">All pending models</option>
                        </select>
                        <p id="batchStatus" class="hint">Batch progress not initialized.</p>
                    </div>
                </div>

                <div class="model-id-list-header" aria-hidden="true">
                    <span>ID</span>
                    <span>Model and creator</span>
                    <span></span>
                </div>
                <ul id="modelIdList" class="model-id-list" aria-label="Model IDs list"></ul>
                <nav id="modelListPagination" class="model-list-pagination hidden" aria-label="Model list pages">
                    <button id="modelListPrevBtn" type="button" class="btn btn-secondary btn-inline">Previous</button>
                    <span id="modelListPageInfo" class="model-list-page-info">Page 1 of 1</span>
                    <button id="modelListNextBtn" type="button" class="btn btn-secondary btn-inline">Next</button>
                    <span id="modelListTotalInfo" class="model-list-total-info"></span>
                </nav>
                <textarea id="idsInput" class="hidden" tabindex="-1" aria-hidden="true"></textarea>
                <p class="hint catalog-load-hint">All modes use objectPreviews. Large libraries are processed in chunks; the list shows 20 rows per page.</p>

                <details class="category-section" id="categorySectionPanel" open>
                    <summary id="categorySelectionHeading" class="subheading">Categories and subcategories</summary>
                    <p class="hint">Selections are saved and written to each generated model JSON with category ID and subcategory IDs.</p>
                    <div id="categorySelectionList" class="category-selection-list" aria-live="polite"></div>
                    <p id="categorySelectionSummary" class="hint">No categories selected.</p>
                </details>

                <label for="downloadRootInput">Download folder</label>
                <div class="path-picker">
                    <input id="downloadRootInput" type="text" placeholder="C:\\Users\\YourName\\Desktop\\models_downloads">
                    <button id="browseDownloadRootBtn" type="button" class="btn btn-secondary btn-inline">Browse...</button>
                    <button id="openDownloadRootBtn" type="button" class="btn btn-secondary btn-inline">Open folder</button>
                </div>
                <p class="hint">Step 1 and Step 2 use this folder. If empty, default is your system Downloads folder.</p>

                <div class="download-history-box">
                    <p class="hint download-history-title">Saved download folders</p>
                    <ul id="downloadHistoryList" class="download-history-list" aria-label="Saved download folders"></ul>
                </div>

                <label class="checkline" for="testModeCheck">
                    <input id="testModeCheck" type="checkbox" checked>
                    I will run enhanced Step 2 in --test mode first.
                </label>

                <div class="button-row">
                    <button id="autoLoadMyIdsBtn" type="button" class="btn btn-primary">Auto load my IDs</button>
                    <button id="resetBatchProgressBtn" type="button" class="btn btn-secondary">Reset batch progress</button>
                    <button id="clearCatalogBtn" type="button" class="btn btn-secondary">Clear model list</button>
                    <button id="clearSessionBtn" type="button" class="btn btn-secondary">Clear session</button>
                    <button id="validateBtn" type="button" class="btn btn-secondary">Validate setup</button>
                </div>
                <p class="hint">Auto load uses objectPreviews (usually one large JSON). Pagination is only used if the API signals it.</p>

                <p id="statusMessage" class="status status-neutral">Ready to validate.</p>
            </section>

            <section class="panel reveal delay-4" aria-labelledby="requirements-heading">
                <div class="panel-header">
                    <h2 id="requirements-heading">Workflow requirement check</h2>
                </div>

                <ul id="requirementsList" class="requirements-list" aria-live="polite"></ul>

                <div class="progress-track" aria-hidden="true">
                    <div id="readinessBar" class="progress-bar"></div>
                </div>
                <p id="readinessText" class="hint"></p>

                <div class="button-row">
                    <button id="downloadIdsBtn" type="button" class="btn btn-primary">Download model_ids.txt</button>
                    <button id="copyCommandsBtn" type="button" class="btn btn-secondary">Copy command plan</button>
                </div>

                <h3 class="subheading">Preview (valid IDs only)</h3>
                <pre id="idsPreview" class="preview">No valid IDs yet.</pre>

                <h3 class="subheading">Selected categories summary</h3>
                <pre id="categorySelectionPreview" class="preview">No categories selected.</pre>
            </section>
        </section>

        <section class="panel reveal delay-5" aria-labelledby="workflow-heading">
            <div class="panel-header">
                <h2 id="workflow-heading">Workflow commands</h2>
            </div>

            <ol class="steps">
                <li>
