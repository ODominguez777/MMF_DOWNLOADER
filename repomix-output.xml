    const maxLength = Number.parseInt(elements.maxLengthInput.value, 10);
    const safeLength = Number.isNaN(maxLength) ? 80 : Math.max(10, Math.min(160, maxLength));

    if (runtimePlatform === "win32") {
        return [
            "# 3_extract_all_zips.ps1",
