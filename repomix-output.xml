let activeRun = null;
let runCounter = 0;

function configureStoragePaths() {
    try {
        const appDataRoot = app.getPath("appData");
        const userDataPath = path.join(appDataRoot, APP_STORAGE_DIR);
        const cachePath = path.join(userDataPath, "Cache");
