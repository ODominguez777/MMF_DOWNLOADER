<file path="gui/styles.css">
:root {
    --bg: #eef4f1;
    --ink: #10231d;
    --muted: #456055;
    --surface: rgba(255, 255, 255, 0.84);
    --surface-strong: #ffffff;
    --edge: rgba(16, 35, 29, 0.12);
    --accent: #0f766e;
    --accent-strong: #0a5f59;
    --accent-warm: #de6a42;
    --ok: #1e8f49;
    --warn: #b56900;
    --bad: #bf2f2f;
    --shadow: 0 16px 42px rgba(16, 35, 29, 0.12);
}

* {
    box-sizing: border-box;
}

html,
body {
    margin: 0;
    min-height: 100%;
}

body {
    background: radial-gradient(circle at 12% 8%, rgba(15, 118, 110, 0.2), transparent 40%),
        radial-gradient(circle at 88% 2%, rgba(222, 106, 66, 0.18), transparent 36%),
        linear-gradient(145deg, #e7f0ec 0%, #f2f7f5 45%, #f8faf9 100%);
    color: var(--ink);
    font-family: "Sora", "Segoe UI", sans-serif;
    line-height: 1.5;
    padding: 24px;
    overflow-x: hidden;
}

.bg-grid {
    position: fixed;
    inset: 0;
    pointer-events: none;
    background-image: linear-gradient(rgba(16, 35, 29, 0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(16, 35, 29, 0.04) 1px, transparent 1px);
    background-size: 32px 32px;
    mask-image: radial-gradient(circle at center, black 30%, transparent 95%);
}

.bg-orb {
    position: fixed;
    border-radius: 999px;
    filter: blur(46px);
    pointer-events: none;
    z-index: 0;
}

.bg-orb-a {
    width: 280px;
    height: 280px;
    left: -80px;
    bottom: 12vh;
    background: rgba(15, 118, 110, 0.22);
}

.bg-orb-b {
    width: 240px;
    height: 240px;
    right: -70px;
    top: 20vh;
    background: rgba(222, 106, 66, 0.24);
}

.app-shell {
    position: relative;
    z-index: 1;
    width: min(1180px, calc(100vw - 48px));
    margin-inline: auto;
    display: grid;
    gap: 16px;
}

.app-shell > * {
    min-width: 0;
}

.hidden {
    display: none !important;
}

.desktop-gate {
    position: fixed;
    inset: 0;
    z-index: 120;
    display: grid;
    place-items: center;
    padding: 18px;
    background: rgba(8, 19, 15, 0.66);
    backdrop-filter: blur(6px);
}

.desktop-card {
    width: min(740px, 100%);
    border-radius: 18px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.94);
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.32);
    padding: 18px;
}

.desktop-card h2 {
    margin-bottom: 8px;
}

.dep-log {
    min-height: 130px;
    max-height: 200px;
    margin-top: 12px;
}

.hero,
.panel,
.stat-card {
    border: 1px solid var(--edge);
    border-radius: 18px;
    background: var(--surface);
    backdrop-filter: blur(8px);
    box-shadow: var(--shadow);
    min-width: 0;
}

.hero {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 22px;
    gap: 16px;
}

.brand-wrap {
    display: flex;
    align-items: center;
    gap: 14px;
}

.brand-mark {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: linear-gradient(150deg, var(--accent), var(--accent-strong));
    color: #ffffff;
    display: grid;
    place-items: center;
    font-weight: 800;
    letter-spacing: 0.08em;
}

h1,
h2,
h3 {
    margin: 0;
}

h1 {
    font-size: clamp(1.3rem, 2.3vw, 1.75rem);
    font-weight: 800;
}

.hero p {
    margin: 4px 0 0;
    color: var(--muted);
}

.badge {
    align-self: flex-start;
    border-radius: 999px;
    padding: 7px 13px;
    font-size: 0.82rem;
    font-weight: 700;
    border: 1px solid transparent;
}

.badge-ready {
    background: rgba(30, 143, 73, 0.14);
    color: #146d37;
    border-color: rgba(30, 143, 73, 0.35);
}

.badge-offline {
    background: rgba(191, 47, 47, 0.14);
    color: #8f2222;
    border-color: rgba(191, 47, 47, 0.35);
}

.stat-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
}

.stat-card {
    padding: 18px;
    text-align: center;
}

.stat-card h2 {
    font-size: clamp(1.45rem, 2.8vw, 2rem);
    color: var(--accent-strong);
    line-height: 1.1;
