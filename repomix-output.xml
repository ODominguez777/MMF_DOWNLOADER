<file path="README-DESKTOP.md">
# Bulk Downloader (Desktop v1.1)

Desktop app (Electron) + Bash/PowerShell scripts to bulk-download **your** MyMiniFactory library.

## Quick start (recommended)

1. `npm install` then `npm start`
2. **Open MyMiniFactory** → sign in → **Capture session**
3. **Auto load my IDs** (catalog loads in pages of 25 from the store API)
4. Remove any models you do not want from the list
5. **Execute Pipeline** (Step 1 metadata → Step 2 test → Step 2 full)

See also: [DESKTOP_EXE.md](DESKTOP_EXE.md) (build installer), [CHANGELOG.md](CHANGELOG.md).

## Rate limits (conservative)

| Step | Delay |
|------|--------|
| Metadata (Step 1) | 6 s between models |
| STL/ZIP (Step 2) | 5 s between files |
| Images | 3 s |
| Catalog pages | 1 s between store API pages |

## Resume after session expiry

- Step 1 skips existing `model_<id>.json` files.
- Step 2 skips files already on disk.
- If the session expires mid-run, capture a new session and re-run; completed work is kept.

## Auth

- Primary: embedded browser + **Capture session** (encrypted storage when OS keychain is available).
- Fallback: **Advanced → manual credentials** in the Configuration panel.

## Scripts (CLI)

| Step | Script |
|------|--------|
| 1 | `1_mmf_download_metadata.sh` |
| 2 | `mmf_download_stl_files_enhanced.sh` |
| 3 | `3_extract_all_zips.ps1` / `.sh` |
| 4 | `4_rename_folders_from_json.ps1` / `.sh` |

`model_ids.txt` is generated by the app; see `model_ids.example.txt`.

## Legal

Use only for models you own. Respect MyMiniFactory terms of service and rate limits.
</file>

<file path="scripts/generate-icons.js">
const fs = require("fs");
const path = require("path");
const sharp = require("sharp");

const projectRoot = path.resolve(__dirname, "..");
const srcSvgPath = path.join(projectRoot, "gui", "myminifactory_downloader_icon.svg");
const buildDir = path.join(projectRoot, "build");
const outSvgPath = path.join(buildDir, "icon.svg");
const outPngPath = path.join(buildDir, "icon.png");
const outIcoPath = path.join(buildDir, "icon.ico");
const outIcnsPath = path.join(buildDir, "icon.icns");
const tempDir = path.join(buildDir, ".icon-tmp");

async function main() {
    const [{ default: pngToIco }, { Icns, IcnsImage }] = await Promise.all([
        import("png-to-ico"),
        import("@fiahfy/icns")
    ]);

    if (!fs.existsSync(srcSvgPath)) {
        throw new Error(`Source SVG not found: ${srcSvgPath}`);
    }

    fs.mkdirSync(buildDir, { recursive: true });

    const originalSvg = fs.readFileSync(srcSvgPath, "utf8");
    const normalizedSvg = originalSvg
        .replace(/<svg\s+([^>]*?)width="100%"([^>]*)>/i, '<svg $1width="680" height="680"$2>')
        .replace(/<svg\s+([^>]*?)height="100%"([^>]*)>/i, '<svg $1height="680"$2>');

    fs.writeFileSync(outSvgPath, normalizedSvg, "utf8");

    await sharp(Buffer.from(normalizedSvg), { density: 1024 })
        .resize(1024, 1024, { fit: "contain", background: { r: 0, g: 0, b: 0, alpha: 0 } })
        .png()
        .toFile(outPngPath);

    fs.rmSync(tempDir, { recursive: true, force: true });
    fs.mkdirSync(tempDir, { recursive: true });

    const icoSizes = [16, 24, 32, 48, 64, 128, 256];
    const icnsTypesBySize = new Map([
        [16, "icp4"],
        [32, "icp5"],
        [64, "icp6"],
        [128, "ic07"],
        [256, "ic08"],
        [512, "ic09"],
        [1024, "ic10"]
    ]);

    const allSizes = Array.from(new Set([...icoSizes, ...icnsTypesBySize.keys()]));
    const generatedPngBySize = new Map();

    for (const size of allSizes) {
        const tempPath = path.join(tempDir, `${size}.png`);
        await sharp(outPngPath)
            .resize(size, size)
            .png()
            .toFile(tempPath);
        generatedPngBySize.set(size, tempPath);
    }

    const icoBuffer = await pngToIco(icoSizes.map((size) => generatedPngBySize.get(size)));
    fs.writeFileSync(outIcoPath, icoBuffer);

    const icns = new Icns();
    for (const [size, osType] of icnsTypesBySize.entries()) {
        const pngBuffer = fs.readFileSync(generatedPngBySize.get(size));
        icns.append(IcnsImage.fromPNG(pngBuffer, osType));
    }
    fs.writeFileSync(outIcnsPath, icns.data);

    fs.rmSync(tempDir, { recursive: true, force: true });

    console.log(`Generated: ${outPngPath}`);
    console.log(`Generated: ${outIcoPath}`);
    console.log(`Generated: ${outIcnsPath}`);
    console.log(`Copied SVG: ${outSvgPath}`);
}

main().catch((error) => {
    console.error(error.message || error);
    process.exit(1);
});
</file>

<file path=".github/workflows/build-macos.yml">
name: Build macOS Artifacts

on:
  workflow_dispatch:
  push:
    tags:
      - "v*"

jobs:
  build-macos:
    runs-on: macos-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: 20
          cache: npm

      - name: Install dependencies
        run: npm ci

      - name: Build macOS packages (unsigned)
        env:
          CSC_IDENTITY_AUTO_DISCOVERY: "false"
        run: npm run dist:mac -- --publish never

      - name: Upload macOS artifacts
        uses: actions/upload-artifact@v4
        with:
          name: macos-dist
          path: |
            dist/*.dmg
            dist/*.zip
          if-no-files-found: error
          retention-days: 14
</file>

