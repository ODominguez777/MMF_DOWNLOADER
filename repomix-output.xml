    }

    if (typeof session.medusaJwt === "string" && session.medusaJwt.trim()) {
        elements.jwtInput.value = normalizeJwtValue(session.medusaJwt);
    }

    if (typeof session.medusaPublishableKey === "string" && session.medusaPublishableKey.trim()) {
