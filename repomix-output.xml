    else
        echo -e "${RED}Error: No JSON files found${NC}"
    fi
    exit 1
fi

echo -e "${BLUE}Found $json_count JSON files to process${NC}"
if [[ "$MODEL_IDS_FILTER_ACTIVE" -eq 1 ]]; then
