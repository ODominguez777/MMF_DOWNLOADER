    font-size: 0.88rem;
    overflow-wrap: anywhere;
}

.advanced-panel {
    margin: 10px 0 14px;
    padding: 10px 12px;
    border: 1px solid var(--edge);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.55);
